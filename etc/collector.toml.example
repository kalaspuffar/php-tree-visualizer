# /etc/php-tree-viz/collector.toml

[server]
bind = "127.0.0.1:8088"
max_body_bytes = 67108864          # 64 MiB
queue_capacity = 256

[auth]
token = "REPLACE_ME"               # base64url, ≥32 bytes
session_salt = "REPLACE_ME_TOO"    # base64url, ≥32 bytes, distinct from token

[storage]
data_dir = "/var/lib/php-tree-viz"
retention_days = 30
# disk_capacity_bytes = 53687091200 # 50 GiB — reference denominator
                                    # for the disk-usage gauge's
                                    # `over_threshold` field. Omit to
                                    # leave the threshold disabled
                                    # (the gauge still reports usage).

[finalize]
idle_seconds = 30                  # trace marked finalized after this much silence
tick_seconds = 5
max_pending_seconds = 600          # hard cap before a trace with a non-empty pending
                                   # backlog is force-finalised. Must be >= idle_seconds.
                                   # Under out-of-order delivery, pending rows mean more
                                   # batches are expected; the hard cap is the safety
                                   # net for traces whose resolvers truly never arrive.

[retention]
tick_minutes = 60

[log]
level = "info"
format = "json"                    # or "text"

[observability]
disk_usage_tick_seconds = 3600     # one hour
disk_usage_warn_pct = 80           # 1..=100; gauge emits at warn level
                                   # when data_dir_bytes is at or above
                                   # this percentage of disk_capacity_bytes
                                   # (no-op when disk_capacity_bytes is unset)
