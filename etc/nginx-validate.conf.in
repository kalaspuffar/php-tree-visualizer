# nginx-validate.conf.in — input template used ONLY to
# syntax-check etc/nginx-example.conf. NOT for serving
# traffic.
#
# This is an INPUT template: the `__REPO_ROOT__` placeholder
# below is substituted by `tools/validate-proxy-configs.sh`
# with the absolute path of this checkout at runtime. Do not
# pass this file to `nginx -t -c` directly — the `include`
# would resolve to a literal `__REPO_ROOT__/etc/...` path
# that does not exist.
#
# Usage (the supported entry point):
#   bash tools/validate-proxy-configs.sh --proxy=nginx
# or, for both proxies in one go:
#   bash tools/validate-proxy-configs.sh
#
# The script generates a temporary copy of this wrapper
# inside a fresh tempdir (`mktemp -d`), substitutes
# __REPO_ROOT__ in it, copies /etc/nginx/fastcgi_params
# into the same tempdir, and runs
#   nginx -t -c <tempdir>/nginx.conf -p <tempdir>
# The colocated fastcgi_params is needed because
# etc/nginx-example.conf uses `include fastcgi_params;` —
# a relative include nginx resolves against the directory
# containing the configuration file under test, regardless
# of what `-p` is passed. Bundling them in one tempdir
# makes the relative resolution succeed without depending
# on the host's /etc/nginx layout.
# This wrapper's own pid/log/access paths are absolute
# under /tmp/ so they don't depend on the prefix.
# Expected output: "test is successful" with exit 0.
#
# Why this exists: etc/nginx-example.conf is a server-block
# fragment (location blocks only, no surrounding
# `server { listen ...; }`). nginx -t cannot parse it
# standalone; it needs scaffolding. This file is that
# scaffolding — a complete minimal nginx top-level config
# with one `server { ... include __REPO_ROOT__/etc/nginx-example.conf; ... }`
# under test.
#
# Paths used here all live under /tmp/ so a non-root invocation
# of `nginx -t -c <file>` does not need privileged write access
# to /var/log/nginx/ or /var/run/.

pid /tmp/phptv-nginx-validate.pid;

events {
    worker_connections 64;
}

http {
    error_log  /tmp/phptv-nginx-validate.error.log;
    access_log /tmp/phptv-nginx-validate.access.log;

    # include mime.types if the distro ships one; otherwise
    # the default_type below keeps nginx happy.
    include            /etc/nginx/mime.types;
    default_type       application/octet-stream;

    server {
        listen      8081;
        server_name phptv-validate;
        root        /tmp;

        # The fragment under test. Generated by the install
        # script in production from the same source file.
        include __REPO_ROOT__/etc/nginx-example.conf;
    }
}
